{
  "name": "enviosxpress-whatsapp-bot",
  "version": "3.0.0",
  "description": "Sophia v3 — Motor de Conversión Psicológica para EnviosXpress WhatsApp",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop sophia",
    "pm2:restart": "pm2 restart sophia",
    "pm2:logs": "pm2 logs sophia --lines 50",
    "pm2:status": "pm2 describe sophia",
    "clean": "rmdir /s /q .wwebjs_auth && echo Session cleaned"
  },
  "keywords": ["whatsapp", "bot", "ai", "envios", "ecuador"],
  "author": "EnviosXpress",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^17.3.1",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6"
  }
}
