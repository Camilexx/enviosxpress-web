# ─── Supabase (Requiere proyecto en supabase.com) ─────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-publica
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-privada

# ─── WhatsApp Bot ─────────────────────────────────────────────────────────
GEMINI_API_KEY=tu-gemini-api-key
PHONE_NUMBER_ID=tu-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=tu-business-account-id

# ─── Edge Functions URL (se genera solo) ──────────────────────────────────
VITE_SUPABASE_FUNCTIONS_URL=https://tu-proyecto.supabase.co/functions/v1
